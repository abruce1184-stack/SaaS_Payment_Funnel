-- Explolring conversion rates

with max_status_reached as (
select  
    psl.subscription_id
    ,max(psl.status_id) as max_status
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
group by    
    1
)
, payment_funnel_status as (
select  
    subs.subscription_id
    ,date_trunc('year',order_date) as order_year
    ,current_payment_status
    ,max_status
    ,case when max_status = 5 then 1 else 0 end as completed_payment
    ,case when max_status is not null then 1 else 0 end as started_payment
from 
    public.subscriptions as subs
left join -- Left join used to include subscriptions that have not started payment process
    max_status_reached as msr
    on subs.subscription_id = msr.subscription_id
having 
    order_year >= '2022-01-01' -- removing 2019 test data
)

select 
    order_year
    ,sum(completed_payment) as num_subs_completed_payment
    ,sum(started_payment) as num_subs_started_payment
    ,count(*) total_subs
    ,num_subs_completed_payment * 100 / total_subs as conversion_rate
    ,num_subs_completed_payment * 100 / num_subs_started_payment as workflow_completion_rate
from 
    payment_funnel_status
group by 
    grouping sets (order_year, ())
order by 
    order_year nulls last

-- Looking at Error Rate

with error_subs as (
select
    distinct subscription_id
from 
    public.payment_status_log
where   
    status_id = 0
)

select  
    count(err.subscription_id) * 100 / count(subs.subscription_id) as percent_subs_hit_error
from 
    public.subscriptions as subs
left join   
    error_subs as err
    on subs.subscription_id = err.subscription_id   

-- Error summary counts for graphing

with error_subs as (
select
    distinct subscription_id
from 
    public.payment_status_log
where   
    status_id = 0
)
,
error_list as (
select  
    subs.subscription_id
    ,case when err.subscription_id is not null then 1 else 0 end as has_error
from 
    public.subscriptions as subs
left join  
    error_subs as err
    on subs.subscription_id = err.subscription_id   
)

select
    case when has_error = 1 then 'Error' else 'No Error' end as error_status,
    count(*) AS sub_count
from    
    error_list
group by
    error_status
