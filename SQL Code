-- Intial exploration of the payment data joined with definitions table 

select 
    *
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
order by    
    subscription_id
    ,movement_date
limit 20

-- Intial exploration of the subscsription data

select 
    *
from 
    public.subscriptions
order by    
    subscription_id
limit 20

-- Exploration of a subscription that followed the happy path to payment and still converted. 

select 
    *
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
where 
    subscription_id = '12622'
order by    
    subscription_id
    ,movement_date

-- Exploration of a subscription that did not follow the happy path and is still unpaid. This path ended in an error on the 3rd party vendor and this customer did not go through to complete payment again and has not converted. 

