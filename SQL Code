-- Identify the furthest status each subscribriber has reached.

select  
    psl.subscription_id
    ,max(psl.status_id) as max_status
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
group by    
    1

-- However, some subscriptions have reached a max status of 4 or 5 and could still be sitting in an error state, so we want to identify those as well.  This also does not account for subscriptions that have not started the payment process at all. 

with max_status_reached as (
select  
    psl.subscription_id
    ,max(psl.status_id) as max_status
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
group by    
    1
)

select  
    subs.subscription_id
    ,current_payment_status
    ,max_status
from 
    public.subscriptions as subs
left join -- Left join used to include subscriptions that have not started payment process
    max_status_reached as msr
    on subs.subscription_id = msr.subscription_id

-- This exploration of the data uncovered 8 potential status that subscribers can in.

-- Using the 8 difference catagories identified above we now categorize which step each subscription is in.

with max_status_reached as (
select  
    psl.subscription_id
    ,max(psl.status_id) as max_status
from 
    public.payment_status_log as psl
join
    public.payment_status_definitions as def
    on psl.status_id = def.status_id
group by    
    1
)

select  
    subs.subscription_id
    ,current_payment_status
    ,max_status
    ,case when max_status = 1 then 'Payment Widget Opened'
        when max_status = 2 then 'Payment Info Entered'
        when max_status = 3 and current_payment_status = 0 then 'User Error in Payment Submission'
        when max_status = 3 and current_payment_status != 0 then 'Payment Submitted'
        when max_status = 4 and current_payment_status = 0 then 'Vendor Processing Error'
        when max_status = 4 and current_payment_status !=0 then 'Payment Successful'
        when max_status = 5 then 'Complete'
        when max_status is null then 'Has Not Started'
        end as payment_funnel_status
from 
    public.subscriptions as subs
left join -- Left join used to include subscriptions that have not started payment process
    max_status_reached as msr
    on subs.subscription_id = msr.subscription_id

